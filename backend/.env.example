DATABASE_URL="postgresql://postgres:postgres@localhost:5432/phytoemagry?schema=public"
PORT=3000

# Required for conversation memory/cache
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Required for AI replies and smart conversation summaries
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: only needed for voice-note replies with ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=
ELEVENLABS_VOICE_ID=

# Required for WhatsApp delivery through Evolution
EVOLUTION_URL=
EVOLUTION_INSTANCE_NAME=
AUTHENTICATION_API_KEY=
WEBHOOK_URL=
WEBHOOK_SECRET=
BOT_ENABLE_AUDIO=false

# Optional: only needed if the bot must send media from public storage
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=