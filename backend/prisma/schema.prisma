generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  vendedor
  soporte
}

enum CompanyStatus {
  active
  suspended
  trial
  cancelled
}

enum CompanyUserRole {
  owner
  admin
  manager
  seller
  support
  viewer
}

// ─── COMPANY (tenant root) ──────────────────────────────────────────────────

model Company {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  slug        String        @unique
  legalName   String?       @map("legal_name")
  rnc         String?
  phone       String?
  email       String?
  logoUrl     String?       @map("logo_url")
  address     String?
  status      CompanyStatus @default(trial)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  companyUsers     CompanyUser[]
  configs          Config[]
  botConfigs       BotConfig[]
  companyContexts  CompanyContext[]
  products         Product[]
  orders           Order[]
  whatsappInstances WhatsAppInstance[]
  whatsappJidMappings WhatsAppJidMapping[]
  mediaFiles       MediaFile[]
  conversationMessages ConversationMessage[]
  conversationMemories ConversationMemory[]
  clientMemories   ClientMemory[]
  conversationSummaries ConversationSummary[]
  contactConversationSummaries ContactConversationSummary[]
  contactStates    ContactState[]
  conversationFollowups ConversationFollowup[]

  @@map("companies")
}

model CompanyUser {
  id        String          @id @default(uuid()) @db.Uuid
  companyId String          @map("company_id") @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  role      CompanyUserRole @default(viewer)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId])
  @@map("company_users")
}

// ─── USER ───────────────────────────────────────────────────────────────────

model Client {
  id             String                  @id @default(cuid())
  name           String
  openaiKey      String                  @map("openai_key")
  elevenlabsKey  String?                 @map("elevenlabs_key")
  promptBase     String                  @map("prompt_base")
  configurations Json?
  createdAt      DateTime                @default(now()) @map("created_at")

  @@map("clients")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  phone        String?   @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(vendedor)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  companyUsers CompanyUser[]

  @@map("users")
}

model Config {
  id             Int      @id @default(autoincrement())
  companyId      String   @map("company_id") @db.Uuid
  openaiKey      String   @default("") @map("openai_key")
  elevenlabsKey  String?  @map("elevenlabs_key")
  promptBase     String   @default("Eres un asistente profesional de WhatsApp. Responde con claridad, foco comercial y tono amable.") @map("prompt_base")
  configurations Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  aiSettings     AiSettings?
  botSettings    BotSettings?
  whatsappSettings WhatsAppSettings?

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
  @@index([companyId])
  @@map("config")
}

model AiSettings {
  configId             Int      @id @map("config_id")
  modelName            String   @default("gpt-4o-mini") @map("model_name")
  temperature          Float    @default(0.4)
  maxCompletionTokens  Int      @default(180) @map("max_completion_tokens")
  memoryWindow         Int      @default(6) @map("memory_window")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  config               Config   @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

model BotSettings {
  configId                Int      @id @map("config_id")
  responseCacheTtlSeconds Int      @default(60) @map("response_cache_ttl_seconds")
  spamGroupWindowMs       Int      @default(2000) @map("spam_group_window_ms")
  allowAudioReplies       Boolean  @default(true) @map("allow_audio_replies")
  followupEnabled         Boolean  @default(false) @map("followup_enabled")
  followup1DelayMinutes   Int      @default(10) @map("followup_1_delay_minutes")
  followup2DelayMinutes   Int      @default(30) @map("followup_2_delay_minutes")
  followup3DelayHours     Int      @default(24) @map("followup_3_delay_hours")
  maxFollowups            Int      @default(3) @map("max_followups")
  stopIfUserReply         Boolean  @default(true) @map("stop_if_user_reply")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  config                  Config   @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("bot_settings")
}

model BotConfig {
  id          Int      @id @default(autoincrement())
  companyId   String   @map("company_id") @db.Uuid
  promptBase  String   @map("prompt_base")
  promptShort String   @map("prompt_short")
  promptHuman String   @map("prompt_human")
  promptSales String   @map("prompt_sales")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
  @@index([companyId])
  @@map("bot_config")
}

model CompanyContext {
  id              Int      @id @default(autoincrement())
  companyId       String   @map("company_id") @db.Uuid
  companyName     String   @default("") @map("company_name")
  description     String   @default("")
  phone           String   @default("")
  whatsapp        String   @default("")
  address         String   @default("")
  latitude        Float? 
  longitude       Float?
  googleMapsLink  String   @default("") @map("google_maps_link")
  workingHoursJson Json    @default("[]") @map("working_hours_json")
  bankAccountsJson Json    @default("[]") @map("bank_accounts_json")
  imagesJson      Json    @default("[]") @map("images_json")
  usageRulesJson  Json    @default("{}") @map("usage_rules_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
  @@index([companyId])
  @@map("company_context")
}

model WhatsAppSettings {
  configId           Int      @id @map("config_id")
  webhookSecret      String   @default("") @map("webhook_secret")
  apiBaseUrl         String   @default("") @map("api_base_url")
  apiKey             String   @default("") @map("api_key")
  instanceName       String   @default("") @map("instance_name")
  fallbackMessage    String?  @map("fallback_message")
  audioVoiceId       String?  @map("audio_voice_id")
  elevenLabsBaseUrl  String?  @map("elevenlabs_base_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  config             Config   @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("whatsapp_settings")
}

model ConversationMemory {
  id        String   @id @default(cuid())
  companyId String   @map("company_id") @db.Uuid
  contactId String   @map("contact_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, contactId, createdAt])
  @@map("conversation_memory")
}

model ConversationMessage {
  id        Int      @id @default(autoincrement())
  companyId String   @map("company_id") @db.Uuid
  contactId String   @map("contact_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, contactId, createdAt])
  @@map("conversation_messages")
}

model ClientMemory {
  id           Int      @id @default(autoincrement())
  companyId    String   @map("company_id") @db.Uuid
  contactId    String   @map("contact_id")
  name         String?
  objective    String?
  interest     String?
  objections   Json?
  status       String   @default("nuevo")
  lastIntent   String?  @map("last_intent")
  notes        String?
  personalData Json?    @map("personal_data")
  expiresAt    DateTime @map("expires_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId])
  @@index([expiresAt])
  @@index([companyId])
  @@map("client_memory")
}

model ConversationSummary {
  id         Int      @id @default(autoincrement())
  companyId  String   @map("company_id") @db.Uuid
  contactId  String   @map("contact_id")
  summary    String
  expiresAt  DateTime @map("expires_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId])
  @@index([expiresAt])
  @@index([companyId])
  @@map("conversation_summaries")
}

model ContactState {
  id                  Int      @id @default(autoincrement())
  companyId           String   @map("company_id") @db.Uuid
  contactId           String   @map("contact_id")
  name                String?
  currentIntent       String?  @map("current_intent")
  stage               String   @default("curioso")
  lastInteractionAt   DateTime? @map("last_interaction_at")
  lastBotMessageAt    DateTime? @map("last_bot_message_at")
  purchaseIntentScore Int      @default(0) @map("purchase_intent_score")
  notesJson           Json     @default("{}") @map("notes_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId])
  @@index([companyId, stage])
  @@index([companyId, lastInteractionAt])
  @@map("contact_state")
}

model ContactConversationSummary {
  id           Int      @id @default(autoincrement())
  companyId    String   @map("company_id") @db.Uuid
  contactId    String   @map("contact_id")
  summaryText  String   @map("summary_text")
  keyFactsJson Json     @default("{}") @map("key_facts_json")
  lastMessageId String? @map("last_message_id")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId])
  @@index([companyId, updatedAt])
  @@map("conversation_summary")
}

model ConversationFollowup {
  id                Int      @id @default(autoincrement())
  companyId         String   @map("company_id") @db.Uuid
  contactId         String   @map("contact_id")
  outboundAddress   String?  @map("outbound_address")
  lastMessageFrom   String   @map("last_message_from")
  lastMessageAt     DateTime @map("last_message_at")
  followupStep      Int      @default(0) @map("followup_step")
  isActive          Boolean  @default(true) @map("is_active")
  nextFollowupAt    DateTime? @map("next_followup_at")
  lastFollowupMessage String? @map("last_followup_message")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId])
  @@index([companyId, isActive, nextFollowupAt])
  @@index([companyId, contactId, lastMessageAt])
  @@map("conversation_followup")
}

model WhatsAppInstance {
  id          Int      @id @default(autoincrement())
  companyId   String   @map("company_id") @db.Uuid
  name        String   @unique
  displayName String?  @map("display_name")
  status      String
  phone       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("whatsapp_instances")
}

model WhatsAppJidMapping {
  id           Int      @id @default(autoincrement())
  companyId    String   @map("company_id") @db.Uuid
  instanceName String   @map("instance_name")
  lidJid       String   @map("lid_jid")
  phoneJid     String   @map("phone_jid")
  phoneNumber  String   @map("phone_number")
  pushName     String?  @map("push_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, instanceName, lidJid])
  @@index([companyId, phoneNumber])
  @@map("whatsapp_jid_mappings")
}

model MediaFile {
  id          Int      @id @default(autoincrement())
  companyId   String   @map("company_id") @db.Uuid
  title       String
  description String?
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type")
  createdAt   DateTime @default(now()) @map("created_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("media_files")
}

model Product {
  id                   Int      @id @default(autoincrement())
  companyId            String   @map("company_id") @db.Uuid
  titulo               String
  descripcionCorta     String?  @map("descripcion_corta")
  descripcionCompleta  String?  @map("descripcion_completa")
  precio               Decimal? @db.Decimal(10, 2)
  precioMinimo         Decimal? @map("precio_minimo") @db.Decimal(10, 2)
  stock                Int      @default(0)
  activo               Boolean  @default(true)
  variantesJson        Json     @default("[]") @map("variantes_json")
  imagenesJson         Json     @default("[]") @map("imagenes_json")
  videosJson           Json     @default("[]") @map("videos_json")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, activo])
  @@index([companyId])
  @@map("products")
}

model Order {
  id            Int      @id @default(autoincrement())
  companyId     String   @map("company_id") @db.Uuid
  contactId     String   @map("contact_id")
  productosJson Json     @map("productos_json")
  estado        String   @default("pendiente")
  total         Decimal? @db.Decimal(10, 2)
  direccion     String?
  notas         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, contactId])
  @@index([companyId, estado])
  @@map("orders")
}
