generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id             String                  @id @default(cuid())
  name           String
  openaiKey      String                  @map("openai_key")
  elevenlabsKey  String?                 @map("elevenlabs_key")
  promptBase     String                  @map("prompt_base")
  configurations Json?
  createdAt      DateTime                @default(now()) @map("created_at")

  @@map("clients")
}

model Config {
  id             Int      @id
  openaiKey      String   @default("") @map("openai_key")
  elevenlabsKey  String?  @map("elevenlabs_key")
  promptBase     String   @default("Eres un asistente profesional de WhatsApp. Responde con claridad, foco comercial y tono amable.") @map("prompt_base")
  configurations Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("config")
}

model ConversationMemory {
  id        String   @id @default(cuid())
  contactId String   @map("contact_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([contactId, createdAt])
  @@map("conversation_memory")
}
