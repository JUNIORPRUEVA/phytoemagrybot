{
  "name": "phytoemagrybot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:audit": "node -r ts-node/register scripts/db-audit.ts",
    "db:compare": "node -r ts-node/register scripts/db-compare.ts",
    "db:migrate:local-to-cloud": "node -r ts-node/register scripts/migrate-local-to-cloud.ts",
    "cloud:selftest": "node -r ts-node/register scripts/cloud-selftest.ts",
    "ai:audit": "node -r ts-node/register scripts/ai-audit.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test:auth": "node --test -r ts-node/register test/auth.service.test.ts",
    "test:bot": "node --test -r ts-node/register test/bot.service.test.ts",
    "test:whatsapp": "node --test -r ts-node/register test/whatsapp.service.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.908.0",
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/schedule": "^4.1.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.73.1",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
